.rankings-container {
  background: #f5f6fa;
  min-height: 100vh;
  padding-bottom: 30rpx;
}

.rankings-header {
  background: linear-gradient(135deg, #1a2744 0%, #2d3f6b 100%);
  color: white;
  padding: 40rpx 30rpx;
  text-align: center;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 22rpx;
  opacity: 0.9;
}

.user-stats-card {
  background: white;
  margin: 20rpx 30rpx;
  padding: 25rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-label {
  font-size: 18rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #e66a2c;
}

.stat-divider {
  width: 1rpx;
  background: #eee;
  margin: 0 20rpx;
}

.rankings-list {
  padding: 0 30rpx;
}

.ranking-item {
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
  display: flex;
  align-items: center;
  gap: 15rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  border-left: 4rpx solid transparent;
}

.ranking-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.12);
}

.ranking-item.gold {
  border-left-color: #ffc107;
  background: linear-gradient(90deg, rgba(255, 193, 7, 0.05) 0%, white 100%);
}

.ranking-item.silver {
  border-left-color: #c0c0c0;
  background: linear-gradient(90deg, rgba(192, 192, 192, 0.05) 0%, white 100%);
}

.ranking-item.bronze {
  border-left-color: #cd7f32;
  background: linear-gradient(90deg, rgba(205, 127, 50, 0.05) 0%, white 100%);
}

.rank-badge {
  font-size: 32rpx;
  font-weight: bold;
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f6fa;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.ranking-item.gold .rank-badge {
  background: #fff9e6;
}

.ranking-item.silver .rank-badge {
  background: #f5f5f5;
}

.ranking-item.bronze .rank-badge {
  background: #ffe8d6;
}

.player-info {
  flex: 1;
  min-width: 0;
}

.player-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.player-avatar {
  font-size: 36rpx;
  flex-shrink: 0;
}

.player-details {
  flex: 1;
  min-width: 0;
}

.player-name {
  font-size: 24rpx;
  font-weight: bold;
  color: #1a2744;
  margin-bottom: 4rpx;
}

.player-level {
  font-size: 16rpx;
  color: #999;
}

.player-score {
  text-align: right;
  flex-shrink: 0;
}

.score-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #e66a2c;
}

.score-label {
  font-size: 16rpx;
  color: #999;
}
