.container {
  background: #f5f6fa;
  min-height: 100vh;
  padding-bottom: 30rpx;
}

/* Hero Section */
.hero-section {
  background: linear-gradient(135deg, #1a2744 0%, #2d3f6b 100%);
  padding: 50rpx 30rpx;
  text-align: center;
  color: white;
  position: relative;
  overflow: hidden;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 20rpx;
  position: relative;
  z-index: 1;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.company-name {
  font-size: 28rpx;
  margin-bottom: 15rpx;
  font-weight: 600;
}

.brand {
  font-weight: bold;
  color: #f68b3c;
}

.intro {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
  margin-bottom: 0;
}

/* Quick Stats */
.quick-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 15rpx;
  padding: 20rpx 30rpx;
  margin-top: -30rpx;
  position: relative;
  z-index: 2;
}

.stat-item {
  background: white;
  border-radius: 15rpx;
  padding: 15rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.profile-stat {
  grid-column: span 2;
}

.stat-icon {
  font-size: 32rpx;
}

.stat-text {
  font-size: 16rpx;
  color: #666;
  font-weight: 600;
}

/* Menu Section */
.menu-section {
  padding: 30rpx;
}

.menu-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a2744;
  margin-bottom: 20rpx;
}

.menu {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.menu-item {
  background: white;
  padding: 20rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 15rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  border-left: 4rpx solid transparent;
}

.menu-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.12);
}

.menu-item.featured {
  border-left-color: #e66a2c;
  background: linear-gradient(90deg, rgba(230, 106, 44, 0.05) 0%, white 100%);
}

.menu-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.menu-content {
  flex: 1;
  min-width: 0;
}

.menu-item-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #1a2744;
  margin-bottom: 4rpx;
}

.menu-item-desc {
  font-size: 18rpx;
  color: #999;
}

.menu-arrow {
  font-size: 24rpx;
  color: #ccc;
  flex-shrink: 0;
}

/* Footer */
.footer {
  text-align: center;
  padding: 30rpx;
  color: #999;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #1a2744;
  margin-bottom: 8rpx;
}

.footer-subtext {
  display: block;
  font-size: 18rpx;
  color: #999;
}
