<view class="container">

  <!-- Hero Section -->
  <view class="hero-section">
    <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
    
    <view class="hero-content">
      <view class="company-name">
        Presented by <text class="brand">AC Sports</text>
      </view>
      
      <view class="intro">
        AC Sports is dedicated to helping athletes improve their basketball skills through structured drills, exciting challenges, and professional fitness plans. This mini program is built to train, compete, and grow together.
      </view>
    </view>
  </view>

  <!-- Quick Stats -->
  <view class="quick-stats">
    <view class="stat-item">
      <text class="stat-icon">🎯</text>
      <text class="stat-text">Training Videos</text>
    </view>
    <view class="stat-item">
      <text class="stat-icon">🔥</text>
      <text class="stat-text">Challenges</text>
    </view>
    <view class="stat-item">
      <text class="stat-icon">🏆</text>
      <text class="stat-text">Rankings</text>
    </view>
      <view class="stat-item">
        <text class="stat-icon">💪</text>
        <text class="stat-text">Fitness Plans</text>
      </view>
      <view class="stat-item profile-stat" bindtap="goToProfile">
        <text class="stat-icon">👤</text>
        <text class="stat-text">Profile</text>
      </view>
  </view>

  <!-- Main Navigation Menu -->
  <view class="menu-section">
    <view class="menu-title">Get Started</view>
    
    <view class="menu">

      <view class="menu-item featured" bindtap="goToVideos">
        <view class="menu-icon">🏀</view>
        <view class="menu-content">
          <view class="menu-item-title">Training Videos</view>
          <view class="menu-item-desc">Learn from professional drills</view>
        </view>
        <view class="menu-arrow">→</view>
      </view>

      <view class="menu-item featured" bindtap="goToChallenges">
        <view class="menu-icon">🔥</view>
        <view class="menu-content">
          <view class="menu-item-title">Challenges</view>
          <view class="menu-item-desc">Test your skills and earn points</view>
        </view>
        <view class="menu-arrow">→</view>
      </view>

      <view class="menu-item" bindtap="goToRankings">
        <view class="menu-icon">🏆</view>
        <view class="menu-content">
          <view class="menu-item-title">Rankings</view>
          <view class="menu-item-desc">See how you rank</view>
        </view>
        <view class="menu-arrow">→</view>
      </view>

      <view class="menu-item" bindtap="goToFitnessPlan">
        <view class="menu-icon">💪</view>
        <view class="menu-content">
          <view class="menu-item-title">Fitness Plan</view>
          <view class="menu-item-desc">8-week training program</view>
        </view>
        <view class="menu-arrow">→</view>
      </view>

      <view class="menu-item" bindtap="goToProfile">
        <view class="menu-icon">👤</view>
        <view class="menu-content">
          <view class="menu-item-title">Profile</view>
          <view class="menu-item-desc">Login, progress, and admin access</view>
        </view>
        <view class="menu-arrow">→</view>
      </view>

    </view>
  </view>

  <!-- Footer -->
  <view class="footer">
    <text class="footer-text">Ready to become a better player?</text>
    <text class="footer-subtext">Start with a training video or challenge today!</text>
  </view>

</view>
