.video-player-container {
  background: #f5f6fa;
  min-height: 100vh;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
}

.player-wrapper {
  background: #000;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

.video-element {
  width: 100%;
  height: 400rpx;
  display: block;
}

.video-info {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 25rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.video-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a2744;
  margin-bottom: 12rpx;
}

.video-description {
  font-size: 22rpx;
  color: #666;
  line-height: 1.6;
}

.action-buttons {
  display: flex;
  gap: 15rpx;
  margin-bottom: 30rpx;
}

.btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 15rpx;
  border: none;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  transition: all 0.3s ease;
}

.btn-primary {
  background: #e66a2c;
  color: white;
}

.btn-primary:active {
  background: #d45a1c;
  transform: scale(0.98);
}

.btn-secondary {
  background: #f0f0f0;
  color: #333;
}

.btn-secondary:active {
  background: #e0e0e0;
  transform: scale(0.98);
}

.btn-icon {
  font-size: 24rpx;
}

.back-button {
  text-align: center;
  padding: 20rpx;
  color: #e66a2c;
  font-size: 24rpx;
  font-weight: 600;
}
