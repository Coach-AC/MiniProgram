.admin-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 24rpx;
}

.add-btn {
  background: #e66a2c;
  color: white;
  margin-bottom: 20rpx;
}

.video-item {
  background: white;
  border-radius: 14rpx;
  padding: 22rpx;
  margin-bottom: 18rpx;
}

.video-title {
  color: #1f2b4a;
  font-size: 26rpx;
  font-weight: bold;
}

.video-desc,
.video-meta {
  margin-top: 8rpx;
  color: #666;
  font-size: 20rpx;
}

.actions {
  display: flex;
  gap: 14rpx;
  margin-top: 16rpx;
}
